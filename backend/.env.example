# Local PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/crowdaid
DB_USERNAME=crowdaid_user
DB_PASSWORD=crowdaid_password

# Supabase PostgreSQL (production) example:
# Use the "Transaction pooler" host from Supabase and add sslmode=require
# DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# DB_USERNAME=postgres.<project_ref>
# DB_PASSWORD=<supabase_db_password>

JWT_SECRET=change-me-to-a-very-long-random-secret-key-at-least-32-chars
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=14

TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_OTP_TEMPLATE=Your CrowdAid OTP is %s. It expires in 10 minutes.

# Local:
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production example:
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_FIRST_NAME=Platform
ADMIN_LAST_NAME=Admin
ADMIN_PHONE=+919000000000

# Optional pool tuning
DB_MIN_IDLE=5
DB_MAX_POOL_SIZE=20
DB_CONNECTION_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=600000
DB_MAX_LIFETIME_MS=1800000
DB_KEEPALIVE_TIME_MS=300000
